{
    "indentWidth": 4,
    "lineWidth": 120,
    "newLineKind": "auto",
    "useTabs": false,
    "json": {
        "trailingCommas": "never"
    },
    "markdown": {
        "textWrap": "always",
        "lineWidth": 80
    },
    "yaml": {
        "indentWidth": 2,
        "quotes": "preferSingle"
    },
    "gofumpt": {
        "langVersion": "go1.26",
        "modulePath": "github.com/jakebailey/gocachez"
    },
    "excludes": [
        "**/.git",
        "**/node_modules",
        "**/*-lock.json"
    ],
    "plugins": [
        "https://plugins.dprint.dev/json-0.21.3.wasm",
        "https://plugins.dprint.dev/markdown-0.20.0.wasm",
        "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
        "https://plugins.dprint.dev/jakebailey/gofumpt-v0.0.12.wasm"
    ]
}
